// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clients   Client[] // Added this line
}

model Client {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  name      String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  songs     Song[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Song {
  id        String   @id @default(cuid())
  title     String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  variations SongVariation[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SongVariation {
  id        String   @id @default(cuid())
  name      String // e.g., "Radio Edit", "Extended Mix", "Acoustic"
  songId    String
  song      Song     @relation(fields: [songId], references: [id])
  comments  Comment[]
  // Add other relevant fields for a variation, e.g., audioFileUrl, lyrics, key, bpm
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id              String        @id @default(cuid())
  text            String
  songVariationId String
  songVariation   SongVariation @relation(fields: [songVariationId], references: [id])
  // userId       String // Optional: to link comment to a specific user
  // user         User   @relation(fields: [userId], references: [id]) // Optional
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}
